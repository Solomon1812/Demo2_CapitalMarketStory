@page
@model Demo2_CapitalMarketStory.Pages.Companies.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>

<form asp-page="./Index" method="get">
    <div class="form-actions">
        <p>
            Find company by name or CUI (Activity type):
            </br>
            <input type="text" name="SearchString" value="@Model.CurrentFilter" />
            <input type="submit" value="Search" class="btn btn-primary" /> |
            <a asp-page="./Index">Back to full list</a>
        </p>
    </div>
</form>


<table class="table">
    <thead>
        <tr>
            <th>
                <a asp-page="./Index" asp-route-sortOrder="@Model.CompanySort">
                    @Html.DisplayNameFor(model => model.Company[0].Name)
                </a>
            </th>

            <th>
                @Html.DisplayNameFor(model => model.Company[0].CUI)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Company[0].FoundedDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Company[0].CAEN)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Company[0].HeadquartersAddress)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Company[0].PhoneNumber)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Company[0].Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Company[0].Website)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in @Model.Company)
        {

            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Name)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.CUI)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.FoundedDate)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.CAEN)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.HeadquartersAddress)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.PhoneNumber)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Email)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Website)
                </td>
                <td>
                    <a asp-page="/Imports/Create" asp-route-companyId="@item.CompanyId">Add import file</a> |
                    <a asp-page="./Edit" asp-route-id="@item.CompanyId">Edit</a> |
                    <a asp-page="./Details" asp-route-id="@item.CompanyId">Details</a> |
                    <a asp-page="./Delete" asp-route-id="@item.CompanyId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
