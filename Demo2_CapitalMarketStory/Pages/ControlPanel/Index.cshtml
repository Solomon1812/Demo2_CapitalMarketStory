@page
@model Demo2_CapitalMarketStory.Pages.ControlPanel.IndexModel
@{
    ViewData["Title"] = "Panou Administrare";
}

<div class="container mt-4">
    <h2 class="mb-4">Panou de Control Administrator</h2>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-info">
            @Model.StatusMessage
        </div>
    }

    <!-- SECȚIUNEA 1: STATISTICI PLATFORMĂ -->
    <div class="row mb-5">
        <div class="col-md-4">
            <div class="card text-white bg-primary mb-3">
                <div class="card-body text-center">
                    <h5 class="card-title">Utilizatori inregistrați</h5>
                    <h2>@Model.TotalUsers</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-success mb-3">
                <div class="card-body text-center">
                    <h5 class="card-title">Companii monitorizate</h5>
                    <h2>@Model.TotalCompanies</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-dark bg-warning mb-3">
                <div class="card-body text-center">
                    <h5 class="card-title">Rapoarte procesate</h5>
                    <h2>@Model.TotalReports</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- SECȚIUNEA 2: GESTIUNE UTILIZATORI -->
    <div class="card">
        <div class="card-header bg-dark text-white">
            Gestiune Utilizatori
        </div>
        <div class="card-body">
            <table class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>Email Utilizator</th>
                        <th>Rol Curent</th>
                        <th>Acțiuni</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.UsersList)
                    {
                        <tr>
                            <td>@user.Email</td>
                            <td>
                                <!-- Aici am inlocuit operatorul ternar cu un if-else clasic -->
                                @if (user.Role == "Admin")
                                {
                                    <span class="badge bg-danger">@user.Role</span>
                                }
                                else if (user.Role == "Investor")
                                {
                                    <span class="badge bg-success">@user.Role</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary">@user.Role</span>
                                }
                            </td>
                            <td>
                                @if (user.Role != "Admin")
                                {
                                    <form method="post" asp-page-handler="DeleteUser" style="display:inline;">
                                        <input type="hidden" name="idToDelete" value="@user.ID" />
                                        <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('ATENȚIE: Ștergerea utilizatorului îi va șterge și toate datele. Continuăm?');">
                                            Șterge Cont
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>