@page
@model Demo2_CapitalMarketStory.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard";

    var FirstYearReported = Model.FinancialReports.FirstOrDefault().Import.StartYear;
    var LastYearReported = Model.FinancialReports.FirstOrDefault().Import.EndYear;

    var ImportDate = Model.FinancialReports.FirstOrDefault().Import.ImportDate.ToString("dd.MM.yyyy");
}

<h2>Evolutia companiei: @Model.Company?.Name</h2>
<p style="color: gray; font-style: italic; margin-bottom: 20px;">
    Analiză generată la data de: @ImportDate
</p>

<h3 style="color:darkblue;">Status curent (pe baza ultimului an): @Model.CompanyStatus</h3>
<h3 style="color:darkblue;">Scor insolventa: @Model.AltmanZScore.ToString("F2") - indicand @Model.InsolvencyRisk</h3>


<div style="background-color: whitesmoke; border-left: 5px solid orange; padding: 15px; margin-top: 20px; max-width: 900px; margin-left: auto; margin-right: auto;">
    <h4 >Audit</h4>
    
    <p>
        Capitalul real curent : <strong>@Model.RealCurrentCapital.ToString("N0") RON</strong>
    </p>
    <p>
        Valoarea estimată (Potențialul de piață): <strong>@Model.PredictedCapValue.ToString("N0") RON</strong>
    </p>

    <hr style="border-top: 1px solid black; "/>
</div>

<br />
<h3>Indicatori de performanta anuali</h3>


<div style="width: 100%; max-width: 900px; margin: auto;">
    <canvas id="myChart1"></canvas>
</div>

<div style="width: 100%; max-width: 900px; margin: auto; margin-top: 30px;">
    <canvas id="myChart2"></canvas>
</div>

<hr>
<br />
<h3>Rezumatul companiei tale</h3>
<br />

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Rezumatul companiei tale</h3>
    <button onclick="downloadCSV('Indicatori_KPI_@(Model.Company?.Name).csv')" class="btn btn-success shadow-sm">
        Descarcă Tabel (CSV)
    </button>
</div>

<table class="table table-striped" id="kpiTable">
    <thead>
        <tr>
            <th>Anul</th>
            <th>ROA</th>
            <th>ROE</th>
            <th>Marja profitului</th>
            <th>Creșterea cifrei de afaceri</th>
            <th>Creștere profit net</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var report in Model.FinancialReports)
        {
            if (report.YearReported == FirstYearReported || report.YearReported > LastYearReported)
            {
                continue;
            }

            <tr>
                <td>@report.YearReported</td>
                <td>@report.ROA.ToString("P2")</td>
                <td>@report.ROE.ToString("P2")</td>
                <td>@report.MarjaProfit.ToString("P2")</td>
                <td>
                    @if (report.RataCrestereCifraAfaceriNet == 0)
                    {
                        <span>N/A</span>
                    }
                    else
                    {
                        @report.RataCrestereCifraAfaceriNet.ToString("P2")
                    }
                </td>
                <td>
                    @if (report.RataCrestereProfitNet == 0)
                    {
                        <span>N/A</span>
                    }
                    else
                    {
                        @report.RataCrestereProfitNet.ToString("P2")
                    }
                </td>
            </tr>
        }
    </tbody>
</table>



@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
        const FirstYearReported = @FirstYearReported;
        const LastYearReported = @LastYearReported;

        const rawData = @Html.Raw(Json.Serialize(
            Model.FinancialReports
                .Where(r => r.YearReported > FirstYearReported)
                .Select(r => new { 
                    r.YearReported, 
                    ProfitNet = r.ProfitNet - r.PierdereNet, 
                    ROE = r.ROE * 100 
                })
        ));

        const realYears = rawData.map(d => d.yearReported); 
        const profitData = rawData.map(d => d.profitNet);
        const roeData = rawData.map(d => d.roe);
        const bckgColor = realYears.map(() => 'rgb(54, 162, 235)'); 

        const predictedProfit = @Model.PredictedProfit2025.ToString(System.Globalization.CultureInfo.InvariantCulture);
        const nextYear = realYears[realYears.length - 1] + 1;
        
        const chart1Years = [...realYears, nextYear]; 
        const chart1ProfitData = [...profitData, predictedProfit];
        const chart1BckgColor = [...bckgColor, 'rgb(255, 159, 64)']; 

        const yAxisFormatter = {
            callback: function(value) {
                const abs = Math.abs(value);
                if (abs >= 1000000000) return (value / 1000000000).toFixed(1) + ' Mld';
                if (abs >= 1000000) return (value / 1000000).toFixed(1) + ' Mil';
                return value;
            }
        };


        const ctx1 = document.getElementById('myChart1');
        if(ctx1) { 
            new Chart(ctx1, {
                type: 'bar',
                data: {
                    labels: chart1Years,
                    datasets: [{
                        label: 'Profit net (RON)',
                        data: chart1ProfitData, 
                        backgroundColor: chart1BckgColor,
                        borderColor: "rgb(0, 0, 0)",
                        borderWidth: 1
                    }]
                },
                options: { responsive: true, 
                    scales: { y: { beginAtZero: true, ticks: yAxisFormatter } } }
            });
        }


        const ctx2 = document.getElementById('myChart2');
        if(ctx2) {
            new Chart(ctx2, {
                type: 'line', 
                data: {
                    labels: realYears, 
                    datasets: [{
                        label: 'Eficiența Capitalului (ROE %)',
                        data: roeData, 
                        borderColor: 'rgb(75, 192, 192)', 
                        backgroundColor: 'rgba(75, 192, 192, 0.2)', 
                        borderWidth: 3,
                        tension: 0.3, 
                        fill: true,
                        pointBackgroundColor: bckgColor, 
                        pointRadius: 5
                    }]
                },
                options: { 
                    responsive: true, 
                    scales: { 
                        y: { 
                            ticks: { 
                                callback: function(value) { return value + '%'; } 
                            } 
                        } 
                    } 
                }
            });
        }



        // DESCĂRCARE TABEL ÎN CSV
        function downloadCSV(filename) {
            let csv = [];
            let rows = document.querySelectorAll("table#kpiTable tr");
            
            for (let i = 0; i < rows.length; i++) {
                let row = [], cols = rows[i].querySelectorAll("td, th");
                
                for (let j = 0; j < cols.length; j++) {
                    let data = cols[j].innerText.replace(/(\r\n|\n|\r)/gm, "").trim();
                    row.push('"' + data + '"');
                }
                csv.push(row.join(","));
            }

            let csvFile = new Blob([csv.join("\n")], {type: "text/csv"});
            let downloadLink = document.createElement("a");
            downloadLink.download = filename;
            downloadLink.href = window.URL.createObjectURL(csvFile);
            downloadLink.style.display = "none";
            document.body.appendChild(downloadLink);
            downloadLink.click();
            document.body.removeChild(downloadLink);
        }


    </script>
    
}
