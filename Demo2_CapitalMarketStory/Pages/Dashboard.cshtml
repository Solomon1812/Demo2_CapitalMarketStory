@page
@model Demo2_CapitalMarketStory.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard";

    var FirstYearReported = Model.FinancialReports.FirstOrDefault().Import.StartYear;
    var LastYearReported = Model.FinancialReports.FirstOrDefault().Import.EndYear;
}

<h2>Evolutia companiei: @Model.Company?.Name</h2>
<h3 style="color:darkblue;">Status curent (pe baza ultimului an): @Model.CompanyStatus</h3>

<br />
<h3>Indicatori de performanta anuali</h3>


<div style="width: 100%; max-width: 900px; margin: auto; margin-top: 30px;">
    <canvas id="myChart1"></canvas>
</div>

<div style="width: 100%; max-width: 900px; margin: auto; margin-top: 30px;">
    <canvas id="myChart2"></canvas>
</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const years = @Html.Raw(Json.Serialize(
                    Model.FinancialReports
                    .Where(r => r.YearReported > FirstYearReported)
                    .Select(r => r.YearReported)));

        const LastYearReported = @LastYearReported;

        const bckgColor = [];
        const borderColor = [];

        for (let i = 0; i < years.length; i++) {

            let crrtYear = years[i];

            if (crrtYear > LastYearReported) {
                bckgColor.push('rgba(255, 159, 64)');
                borderColor.push('rgba(255, 159, 64)');
            }
            else {
                bckgColor.push('rgba(54, 162, 235)');
                borderColor.push('rgba(54, 162, 235)');
            }
        }

        const ctx1 = document.getElementById('myChart1');

        new Chart(ctx1, {
            type: 'bar',
            data: {
            labels: @Html.Raw(Json.Serialize(Model.FinancialReports.Select(r => r.YearReported))),
            datasets: [{
                label: 'Profit net (RON)',
                data: @Html.Raw(Json.Serialize(Model.FinancialReports.Select(r => r.ProfitNet))),
                backgroundColor: bckgColor,
                borderColor: borderColor,
                borderWidth: 1
            }]
            },
            options: {
            responsive: true,
            scales: {
                y: {
                beginAtZero: true
                }
            }
            }
        });

        const ctx2 = document.getElementById('myChart2');

        new Chart(ctx2, {
            type: 'bar',
            data: {
            labels: @Html.Raw(Json.Serialize(Model.FinancialReports.Select(r => r.YearReported))),
            datasets: [{
                label: 'Cifra de afaceri neta (RON)',
                data: @Html.Raw(Json.Serialize(Model.FinancialReports.Select(r => r.CifraAfaceriNet))),
                backgroundColor: bckgColor,
                borderColor: borderColor,
                borderWidth: 1
            }]
            },
            options: {
            responsive: true,
            scales: {
                y: {
                beginAtZero: true
                }
            }
            }
        });

    </script>
}


<table class="table">
    <thead>
        <tr>
            <th>Anul</th>
            <th>ROA</th>
            <th>ROE</th>
            <th>Marja Profitului</th>
            <th>Creștere CA</th>
            <th>Creștere Profit Net</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var report in Model.FinancialReports)
        {
            if (report.YearReported == FirstYearReported || report.YearReported > LastYearReported)
            {
                continue;
            }

            <tr>
                <td>@report.YearReported</td>
                <td>@Html.DisplayFor(modelItem => report.ROA)</td> @* sau <td>@Html.DisplayFor(modelItem => report.ROA)</td> annotation model *@
                <td>@report.ROE.ToString("P2")</td>
                <td>@report.MarjaProfit.ToString("P2")</td>
                <td>
                    @if (report.RataCrestereCifraAfaceriNet == 0)
                    {
                        <span>N/A</span>
                    }
                    else
                    {
                        @report.RataCrestereCifraAfaceriNet.ToString("P2")
                    }
                </td>

                <td>
                    @if (report.RataCrestereProfitNet == 0)
                    {
                        @("N/A")
                    }
                    else
                    {
                        @report.RataCrestereProfitNet.ToString("P2")
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

