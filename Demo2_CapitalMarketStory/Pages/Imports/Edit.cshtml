@page
@model Demo2_CapitalMarketStory.Pages.Imports.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Import</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="Import.ImportId" />
            <input type="hidden" asp-for="Import.CompanyId" />
            
            <div class="form-group">
                <label asp-for="Import.ImportDate" class="control-label"></label>
                <input asp-for="Import.ImportDate" class="form-control" readonly />
                <span asp-validation-for="Import.ImportDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Import.FileName" class="control-label"></label>
                <input asp-for="Import.FileName" class="form-control" readonly />
                <span asp-validation-for="Import.FileName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Import.Description" class="control-label"></label>
                <input asp-for="Import.Description" class="form-control" />
                <span asp-validation-for="Import.Description" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
