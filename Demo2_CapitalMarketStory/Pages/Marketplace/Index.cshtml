@page
@model Demo2_CapitalMarketStory.Pages.Marketplace.IndexModel
@{
    ViewData["Title"] = "Marketplace Investiții";
}

<div class="text-center mb-4">
    <h2>Marketplace Investiții</h2>
    <p>Aici puteți vizualiza companiile analizate, grupate pe domenii (CAEN), și contacta antreprenorii.</p>
</div>

<div class="row">
    @if (!Model.AvailableCompanies.Any())
    {
        <div class="alert alert-info">Momentan nu există companii cu date financiare analizate.</div>
    }
    else
    {
        @foreach (var item in Model.AvailableCompanies)
        {
            <div class="col-md-4 mb-4">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title">@item.Company.Name</h4>
                        <h6 class="card-subtitle text-muted mb-3">CAEN: @item.Company.CAEN</h6>

                        <ul class="list-group list-group-flush">
                            <li class="list-group-item d-flex justify-content-between">
                                <span>Status Altman:</span>

                                <!-- Operatorul ternar inlocuit cu if-else clasic -->
                                @if (item.CompanyStatus.Contains("Performanta") || item.CompanyStatus.Contains("Stabil"))
                                {
                                    <span class="badge bg-success">@item.CompanyStatus</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">@item.CompanyStatus</span>
                                }
                            </li>

                            <li class="list-group-item d-flex justify-content-between">
                                <span>Profit Real (Ultimul An):</span>
                                <strong>@item.RealProfit.ToString("N0") RON</strong>
                            </li>

                            <li class="list-group-item d-flex justify-content-between">
                                <span>Profit Estimat (Viitor):</span>
                                <strong>@item.PredictedProfit.ToString("N0") RON</strong>
                            </li>

                            <li class="list-group-item d-flex justify-content-between">
                                <span>Capital Real Curent:</span>
                                <strong>@item.RealCapital.ToString("N0") RON</strong>
                            </li>

                            <li class="list-group-item d-flex justify-content-between">
                                <span>ROA / ROE:</span>
                                <span>
                                    <strong>@item.ROA.ToString("P2")</strong> /
                                    <strong>@item.ROE.ToString("P2")</strong>
                                </span>
                            </li>
                        </ul>
                    </div>

                    <div class="card-footer text-center">
                        <a href="mailto:@item.OwnerEmail?subject=Propunere de investitie: @item.Company.Name&body=Buna ziua, am analizat performanta financiara (ROA: @item.ROA.ToString("P2")) a companiei dumneavoastra pe platforma CapitalMarketStory si sunt interesat de o colaborare. Putem stabili o discutie?"
                           class="btn btn-success">
                            Contactează Antreprenor
                        </a>
                    </div>
                </div>
            </div>
        }
    }
</div>